# Telegram bot token from @BotFather
BOT_TOKEN=

# Target chat/channel ID the bot posts to (get via @userinfobot or Telegram API)
CHAT_ID=

# Polling intervals (milliseconds)
OREF_POLL_INTERVAL_MS=10000
NEWS_POLL_INTERVAL_MS=300000

# Public Telegram channel username (without @) to relay posts from
